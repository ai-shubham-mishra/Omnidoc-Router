# ============== Required ==============

# MongoDB connection
MONGO_DB_URL=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=omnidoc_v01

# Redis connection (for session caching with 3-day TTL)
REDIS_URL=redis://localhost:6379
# Session TTL in seconds (default: 259200 = 3 days)
SESSION_TTL_SECONDS=259200

# Registered workflows collection name
REGISTERED_WORKFLOW_COLLECTION_NAME=registeredWorkflows

# Google Gemini API key (for LLM router intent matching)
GOOGLE_API_KEY=your-google-api-key

# JWT secret (must match OmniDoc-AgenticAPI)
JWT_SECRET=your-jwt-secret

# Base URL of the AgenticAPI service (where workflows run)
AGENTICAPI_BASE_URL=http://localhost:8400
