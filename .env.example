# ============== Required ==============

# Azure Cosmos DB (Document DB) connection
AZ_COSMOS_DB_URL=mongodb+srv://user:password@cluster.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
AZ_COSMOS_DB_NAME=omnidoc-backend-dev

# Collection Names (Router-relevant)
AZ_COSMOS_DB_REGISTERED_WORKFLOWS_COLLECTION=registeredWorkflows
AZ_COSMOS_DB_CHAT_SESSIONS_COLLECTION=chat_sessions

# Redis connection (for session caching with 3-day TTL)
REDIS_URL=redis://localhost:6379
# Session TTL in seconds (default: 259200 = 3 days)
SESSION_TTL_SECONDS=259200

# Google Gemini API key (for LLM router intent matching)
GOOGLE_API_KEY=your-google-api-key

# JWT secret (must match OmniDoc-AgenticAPI)
JWT_SECRET=your-jwt-secret

# Base URL of the AgenticAPI service (where workflows run)
AGENTICAPI_BASE_URL=http://localhost:8400

# Azure Blob Storage (hierarchical: knowledge-base/<orgId>/<userId>/<sessionId>/<runId>/<stage>/)
AZ_BLOB_CONN_STRING=DefaultEndpointsProtocol=https;AccountName=omnidocdev;...
AZ_BLOB_STORAGE_ACCOUNT_NAME=omnidocdev
AZ_BLOB_CONN_KEY=your-key
AZ_BLOB_CONTAINER_NAME=knowledge-base
AZ_BLOB_BASE_DIRECTORY=knowledge-base
STORAGE_BACKEND=azure
