# ============== Required (Minimal) ==============

# Storage Backend Selection ('azure' or 'local')
STORAGE_BACKEND=azure

# Hierarchical blob base directory
AZ_BLOB_BASE_DIRECTORY=knowledge_base

# ============== Azure Key Vault (Primary Secret Store) ==============
# All secrets below are fetched from Azure Key Vault
# Set these in your .env for local dev ONLY if you need to override Key Vault

AZURE_KEY_VAULT_URL=https://omnidoc-vault.vault.azure.net/
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Pinecone Vector Database
PINECONE_INDEX_NAME=llama-text-embed-v2-index

# ============== Secrets in Azure Key Vault ==============
# These are stored in Key Vault with underscores converted to hyphens:
#   AZ_COSMOS_DB_URL → AZ-COSMOS-DB-URL
#   AZ_BLOB_CONN_STRING → AZ-BLOB-CONN-STRING
#   GOOGLE_API_KEY → GOOGLE-API-KEY
#   JWT_SECRET → JWT-SECRET
#   VECTOR_SEARCH_API_KEY → VECTOR-SEARCH-API-KEY (Pinecone)
#   etc.
#
# The router automatically converts underscores to hyphens when querying Key Vault.
# No need to set these in .env for dev if Key Vault is configured properly.
#
# Secrets in vault:
#   - AZ-COSMOS-DB-URL
#   - AZ-COSMOS-DB-NAME
#   - AZ-BLOB-CONN-STRING
#   - AZ-BLOB-STORAGE-ACCOUNT-NAME
#   - AZ-BLOB-CONN-KEY
#   - AZ-BLOB-CONTAINER-NAME
#   - GOOGLE-API-KEY
#   - JWT-SECRET
#   - REDIS-URL
#   - AGENTICAPI-BASE-URL
#   - VECTOR-SEARCH-API-KEY

# ============== Local Dev Overrides (Optional) ==============
# Only set these if you need to bypass Key Vault for local testing
STORAGE_BACKEND=azure

# Azure Key Vault (for secrets like Pinecone API key)
AZURE_KEY_VAULT_URL=https://omnidoc-vault.vault.azure.net/
# Optional: Service Principal for local testing (omit for managed identity in Azure)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Pinecone Vector Database (for semantic search and long-term context)
# API key is stored in Azure Key Vault as VECTOR-SEARCH-API-KEY
PINECONE_INDEX_NAME=llama-text-embed-v2-index
